{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karaxys.local/contracts/scan.result.v1.schema.json",
  "title": "Karaxys Scan Result",
  "description": "Normalized active-testing result emitted by scanner workers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result_id",
    "job_id",
    "inventory_id",
    "test_type",
    "status",
    "vulnerable",
    "severity",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "scan.result.v1"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "result_id": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "inventory_id": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{24}$"
    },
    "test_type": {
      "type": "string",
      "minLength": 1
    },
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "error", "skipped"]
    },
    "vulnerable": {
      "type": "boolean"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical", "unknown"]
    },
    "description": {
      "type": "string"
    },
    "proof": {
      "description": "Must be redacted before persistence or UI display.",
      "type": "string"
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status_code": {
          "type": "integer",
          "minimum": 0,
          "maximum": 599
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "body_excerpt": {
          "type": "string"
        },
        "body_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "error": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
