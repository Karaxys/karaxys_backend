KARAXYS_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/?directConnection=true
MONGO_DB_NAME=karaxys

PROXY_ADDR=127.0.0.1:8080
PROXY_CERT_FILE=certs/ca.crt
PROXY_KEY_FILE=certs/ca.key

KARAXYS_AGENT_TOKEN=replace-with-a-long-random-token
KARAXYS_API_KEY=replace-with-a-long-random-api-key
KARAXYS_ALLOWED_ORIGINS=http://localhost:7000

# OAuth (optional). If a provider's ID/secret are unset, its login button
# returns 503 and the provider is simply disabled.
# Where the dashboard SPA lives; OAuth callbacks redirect here on success/failure.
KARAXYS_DASHBOARD_URL=http://localhost:7000
# Public base URL of THIS backend; provider redirect URIs are derived as
# <base>/auth/oauth/<provider>/callback. Register that exact URI with each provider.
KARAXYS_OAUTH_REDIRECT_BASE_URL=http://localhost:8081
# Google: console.cloud.google.com -> Credentials -> OAuth client (Web).
KARAXYS_OAUTH_GOOGLE_CLIENT_ID=
KARAXYS_OAUTH_GOOGLE_CLIENT_SECRET=
# GitHub: Settings -> Developer settings -> OAuth Apps. Callback:
# http://localhost:8081/auth/oauth/github/callback
KARAXYS_OAUTH_GITHUB_CLIENT_ID=
KARAXYS_OAUTH_GITHUB_CLIENT_SECRET=
KARAXYS_MAX_WRITE_BYTES=1048576
KARAXYS_INGESTOR_ADDR=:8082
KARAXYS_REDIS_ADDR=127.0.0.1:6379
KARAXYS_REDIS_DB=0
KARAXYS_REDIS_TLS=false
KARAXYS_REDIS_KEY_PREFIX=karaxys
KARAXYS_SCAN_LOCK_TTL_SECONDS=1800
KARAXYS_SCAN_PROGRESS_TTL_SECONDS=7200
KARAXYS_SCANNER_GLOBAL_CONCURRENCY=2
KARAXYS_SCANNER_TARGET_JOBS_PER_WINDOW=1
KARAXYS_SCANNER_TARGET_RATE_WINDOW_SECONDS=30
KARAXYS_SCANNER_CAPACITY_RETRY_SECONDS=5
KARAXYS_SCANNER_ADMISSION_LEASE_SECONDS=1800
KARAXYS_NUCLEI_RATE_LIMIT_PER_SECOND=5
KARAXYS_NUCLEI_TEMPLATE_CONCURRENCY=1
KARAXYS_NUCLEI_HOST_CONCURRENCY=1
KARAXYS_NUCLEI_PAYLOAD_CONCURRENCY=2
KARAXYS_NUCLEI_PROBE_CONCURRENCY=5
KARAXYS_OBJECTSTORE_BUCKET=karaxys-local
KARAXYS_OBJECTSTORE_REGION=us-east-1
KARAXYS_OBJECTSTORE_ENDPOINT=http://127.0.0.1:9000
KARAXYS_OBJECTSTORE_ACCESS_KEY_ID=karaxys
KARAXYS_OBJECTSTORE_SECRET_ACCESS_KEY=karaxys-local-minio-password
KARAXYS_OBJECTSTORE_FORCE_PATH_STYLE=true
KARAXYS_OBJECTSTORE_SSE=
KARAXYS_QUEUE_ENABLED=false
KARAXYS_QUEUE_BROKERS=127.0.0.1:19092
KARAXYS_QUEUE_CLIENT_ID=karaxys-backend
KARAXYS_QUEUE_CONSUMER_GROUP=karaxys-runtime-analyzer
KARAXYS_RUNTIME_ANALYZER_CONSUMER_GROUP=karaxys-runtime-analyzer
KARAXYS_DEAD_LETTER_CONSUMER_GROUP=karaxys-dead-letter-consumer
KARAXYS_SCANNER_WORKER_CONSUMER_GROUP=karaxys-scanner-worker
KARAXYS_QUEUE_TOPICS=karaxys.http.conversations,karaxys.analyzer.jobs,karaxys.ingest.dead_letter,karaxys.scan.jobs
KARAXYS_QUEUE_TOPIC_PARTITIONS=3
KARAXYS_QUEUE_REPLICATION_FACTOR=1
KARAXYS_QUEUE_PRODUCE_TIMEOUT_SECONDS=10
# Required for auth-based scans that pass attacker/manual tokens.
# Generate with: openssl rand -base64 32
KARAXYS_SECRET_KEY_B64=replace-with-a-base64-encoded-32-byte-key

TRAFFIC_LOG_MAX_EVENTS=1000
TRAFFIC_LOG_TTL_HOURS=24
